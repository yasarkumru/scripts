#!/bin/bash
# 1. Kill any existing spoofdpi instances to prevent errors
pkill -f "spoofdpi"

# 2. Start spoofdpi in the background with your working config
# If this fails, provide full path: ~/.spoofdpi/bin/spoofdpi
sudo spoofdpi --dns-mode https --https-fake-count 1 --https-split-mode sni &

# 3. Ensure spoofdpi is killed on exit (covers Ctrl+C, errors, and normal exit)
trap "pkill -f spoofdpi" EXIT

# 4. Wait for spoofdpi to bind to port 8080 (timeout after 10s)
timeout=100
while ! ss -tlnp | grep -q ':8080'; do
    sleep 0.1
    (( timeout-- ))
    if (( timeout == 0 )); then
        echo "spoofdpi failed to start" >&2
        exit 1
    fi
done

# 5. Start Vesktop forcing the proxy settings (overrides system defaults)
flatpak run --env=http_proxy=http://127.0.0.1:8080 --env=https_proxy=http://127.0.0.1:8080 dev.vencord.Vesktop
